{
    "layer": "top", // Waybar at top layer
    "height": 30, // Waybar height (to be removed for auto height)
    "width": 1280, // Waybar width
    "spacing": -20, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": ["custom/logo", "hyprland/workspaces", "custom/media"],
    "modules-center": [],
    "modules-right": ["pulseaudio", "network", "cpu", "battery", "clock", "tray"],
    "custom/logo": {
	"exec": "echo '  ΎΝΥ    '",
	"format": "{}",
	"interval": 5,
	"on-click": "notify-send 'hello-world!'",
	"signal": 8
    },
    "hyprland/workspaces": {
         "all-outputs": true,
         "warp-on-scroll": false,
         "format": "{icon}",
        "on-scroll-up": "hyperctl dispatch workspace e+1",
	"on-scroll-down": "hyperctl dispatch workspace e-1",
         "format-icons": {
             "1": "ΎΕΣ",
             "2": "ΎΕΣ",
             "3": "ΎΕΣ",
             "4": "ΎΕΣ",
             "5": "ΎΕΣ",
             "urgent": "ΎΒς",
             "focused": "ΎΗΤ",
             "default": "ΎΕΣ"
         }
    },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "ΎΑμ",
            "unlocked": "ΎΓε"
        }
    },
    "hyprland/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "hyprland/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "ΎΜΤ"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) έ╕ρ{songPosition}|{queueLength}έ╕σ {volume}% ΎΑΒ",
        "format-disconnected": "Disconnected ΎΑΒ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped ΎΑΒ",
        "unknown-tag": "N/A",
        "interval": 2,
        "consume-icons": {
            "on": "ΎΔΕ "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">ΎΒ┤</span>",
            "on": "ΎΒ┤ "
        },
        "repeat-icons": {
            "on": "ΎΑη"
        },
        "single-icons": {
            "on": "ΎΑη1"
        },
        "state-icons": {
            "paused": "ΎΒΝ",
            "playing": "ΎΒΜ"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ΎΒχ",
            "deactivated": "ΎΒ░"
        }
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
    	"format": " ≤░ξΦ {:%H:%M %B %d}  ",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    },
    "cpu": {
        "format": "{usage}% ΎΜδ {avg_frequency}GHz  ",
        "tooltip": false
    },
    "memory": {
        "format": "{}% ΎΔΚ"
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C {icon}",
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["Ύζτ", "ΎΜΚ", "Ύζσ"]
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}   ",
        "format-charging": "{capacity}% ΎΩπ",
        "format-plugged": "{capacity}% ΎΘο",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "network": {
        "format-wifi": "{essid} ({signalStrength}%) ΎΘτ   ",
        "format-ethernet": "{ipaddr}/{cidr} ΎηΨ   ",
        "tooltip-format": "{ifname} via {gwaddr} ΎηΨ   ",
        "format-linked": "{ifname} (No IP) ΎηΨ   ",
        "format-disconnected ":"Disconnected έγι   ",
        "format-alt": "{ifname}: {ipaddr}/{cidr}   "
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon} {format_source}  ",
        "format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source} ",
        "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source} ",
        "format-muted": "Ύγσ {format_source} ",
        "format-source": "{volume}% ΎΕ░ ",
        "format-source-muted": "ΎΕ▒ ",
        "format-icons": {
            "headphone": "ΎΑξ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol"
    },
    "custom/media": {
        "format": "{icon} {}   ",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "ΎΗ╝",
            "default": "ΏθΟε"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
        // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    }
}

